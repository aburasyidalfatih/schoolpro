generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String                 @id @default(uuid())
  nama                 String
  slug                 String                 @unique
  domainKustom         String?                @map("domain_kustom")
  logoUrl              String?                @map("logo_url")
  alamat               String?
  telepon              String?
  email                String?
  website              String?
  mediaSosial          Json?                  @map("media_sosial")
  pengaturan           Json?
  paket                String                 @default("FREE")
  planId               String?                @map("plan_id")
  tenantStatus         String                 @default("TRIAL") @map("tenant_status")
  berlanggananSampai   DateTime?              @map("berlangganan_sampai")
  trialEndsAt          DateTime?              @map("trial_ends_at")
  isActive             Boolean                @default(true) @map("is_active")
  profileWebsite       Json?                  @map("profile_website")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  activeSubscription   TenantSubscription?
  agendas              Agenda[]
  alumnis              Alumni[]
  akunKas              AkunKas[]
  beritas              Berita[]
  ekskuls              Ekskul[]
  fasilitas            Fasilitas[]
  prestasis            Prestasi[]
  sliders              Slider[]
  berkasPpdbs          BerkasPpdb[]
  kategoriTagihans     KategoriTagihan[]
  kelases              Kelas[]
  logAktivitas         LogAktivitas[]
  pembayarans          Pembayaran[]
  pendaftarPpdbs       PendaftarPpdb[]
  featureOverrides     TenantFeatureOverride[]
  subscriptionOrders   SubscriptionOrder[]
  auditLogs            PlatformAuditLog[]
  pengaturanNotifikasi PengaturanNotifikasi[]
  plan                 Plan?                  @relation(fields: [planId], references: [id], onDelete: SetNull)
  pengumumans          Pengumuman[]
  periodePpdbs         PeriodePpdb[]
  persyaratanBerkas    PersyaratanBerkas[]
  rekenings            Rekening[]
  siswas               Siswa[]
  tabungans            Tabungan[]
  tagihanPpdbs         TagihanPpdb[]
  tagihans             Tagihan[]
  tahunAjarans         TahunAjaran[]
  transaksiKas         TransaksiKas[]
  transaksiTabungans   TransaksiTabungan[]
  units                Unit[]
  users                User[]
  pembayaranPpdbs      PembayaranPpdb[]
  gurus                Guru[]
  blogs                Blog[]
  editorials           Editorial[]
  approvedApplications TenantApplication[]   @relation("ApprovedTenantApplications")

  @@map("tenants")
}

model TenantApplication {
  id                 String    @id @default(uuid())
  applicationCode    String    @unique @map("application_code")
  namaSekolah        String    @map("nama_sekolah")
  jenjang            String
  statusSekolah      String    @map("status_sekolah")
  npsn               String?
  emailSekolah       String    @map("email_sekolah")
  teleponSekolah     String    @map("telepon_sekolah")
  alamat             String
  provinsi           String
  kotaKabupaten      String    @map("kota_kabupaten")
  websiteSaatIni     String?   @map("website_saat_ini")
  jumlahSiswaSaatIni Int?      @map("jumlah_siswa_saat_ini")
  namaPic            String    @map("nama_pic")
  jabatanPic         String    @map("jabatan_pic")
  emailPic           String    @map("email_pic")
  whatsappPic        String    @map("whatsapp_pic")
  slugRequest        String    @map("slug_request")
  slugApproved       String?   @map("slug_approved")
  kebutuhanUtama     String    @map("kebutuhan_utama")
  catatanTambahan    String?   @map("catatan_tambahan")
  sumberLead         String?   @map("sumber_lead")
  status             String    @default("SUBMITTED")
  submittedAt        DateTime? @map("submitted_at")
  reviewedAt         DateTime? @map("reviewed_at")
  reviewedByUserId   String?   @map("reviewed_by_user_id")
  reviewNotes        String?   @map("review_notes")
  revisionNotes      String?   @map("revision_notes")
  rejectedReason     String?   @map("rejected_reason")
  approvedTenantId   String?   @map("approved_tenant_id")
  provisionedAt      DateTime? @map("provisioned_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  approvedTenant     Tenant?   @relation("ApprovedTenantApplications", fields: [approvedTenantId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([emailPic])
  @@index([slugRequest])
  @@map("tenant_applications")
}

model Plan {
  id          String                 @id @default(uuid())
  code        String                 @unique
  name        String
  description String?
  price       Decimal                @default(0)
  studentCapacity Int                @default(0) @map("student_capacity")
  billingPeriod String               @default("YEARLY") @map("billing_period")
  isDefault   Boolean                @default(false) @map("is_default")
  isActive    Boolean                @default(true) @map("is_active")
  isPublic    Boolean                @default(true) @map("is_public")
  fullAccess  Boolean                @default(false) @map("full_access")
  sortOrder   Int                    @default(0) @map("sort_order")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  features    PlanFeature[]
  currentOrders SubscriptionOrder[]  @relation("CurrentPlanOrders")
  targetOrders  SubscriptionOrder[]  @relation("TargetPlanOrders")
  subscriptions TenantSubscription[]
  tenants     Tenant[]

  @@map("plans")
}

model PlanFeature {
  id        String   @id @default(uuid())
  planId    String   @map("plan_id")
  featureKey String  @map("feature_key")
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@map("plan_features")
}

model TenantSubscription {
  id              String    @id @default(uuid())
  tenantId        String    @unique @map("tenant_id")
  planId          String?   @map("plan_id")
  status          String    @default("TRIAL")
  studentCapacity Int       @default(0) @map("student_capacity")
  startsAt        DateTime  @default(now()) @map("starts_at")
  endsAt          DateTime? @map("ends_at")
  activatedAt     DateTime? @map("activated_at")
  lastPaidAt      DateTime? @map("last_paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@map("tenant_subscriptions")
}

model SubscriptionOrder {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  currentPlanId   String?   @map("current_plan_id")
  targetPlanId    String    @map("target_plan_id")
  orderType       String    @default("NEW_SUBSCRIPTION") @map("order_type")
  status          String    @default("PENDING_PAYMENT")
  amount          Decimal   @default(0)
  billingPeriod   String    @default("YEARLY") @map("billing_period")
  studentCapacity Int       @default(0) @map("student_capacity")
  paymentMethod   String?   @map("payment_method")
  paymentProofUrl String?   @map("payment_proof_url")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  paidAt          DateTime? @map("paid_at")
  verifiedAt      DateTime? @map("verified_at")
  activatedAt     DateTime? @map("activated_at")
  expiresAt       DateTime? @map("expires_at")
  notes           String?
  rejectionReason String?   @map("rejection_reason")
  createdByUserId String?   @map("created_by_user_id")
  verifiedByUserId String?  @map("verified_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentPlan     Plan?     @relation("CurrentPlanOrders", fields: [currentPlanId], references: [id], onDelete: SetNull)
  targetPlan      Plan      @relation("TargetPlanOrders", fields: [targetPlanId], references: [id], onDelete: Restrict)

  @@map("subscription_orders")
}

model TenantFeatureOverride {
  id          String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  featureKey   String   @map("feature_key")
  isEnabled    Boolean  @map("is_enabled")
  reason       String?
  expiresAt    DateTime? @map("expires_at")
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@map("tenant_feature_overrides")
}

model PlatformAuditLog {
  id          String   @id @default(uuid())
  actorUserId String?  @map("actor_user_id")
  actorName   String?  @map("actor_name")
  actorRole   String?  @map("actor_role")
  tenantId    String?  @map("tenant_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@map("platform_audit_logs")
}

model User {
  id                 String              @id @default(uuid())
  tenantId           String              @map("tenant_id")
  nama               String
  email              String
  username           String
  passwordHash       String              @map("password_hash")
  role               String              @default("STAF")
  isActive           Boolean             @default(true) @map("is_active")
  lastLogin          DateTime?           @map("last_login")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  beritas            Berita[]
  logAktivitas       LogAktivitas[]
  pembayarans        Pembayaran[]        @relation("PetugasPembayaran")
  pendaftarPpdbs     PendaftarPpdb[]
  pengumumans        Pengumuman[]
  siswas             Siswa[]
  transaksiTabungans TransaksiTabungan[] @relation("PetugasTabungan")
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@map("users")
}

model Unit {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  nama         String
  kode         String
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  kelases      Kelas[]
  periodePpdbs PeriodePpdb[]
  siswas       Siswa[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kode])
  @@map("units")
}

model TahunAjaran {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  nama           String
  tanggalMulai   DateTime      @map("tanggal_mulai")
  tanggalSelesai DateTime      @map("tanggal_selesai")
  isActive       Boolean       @default(false) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  kelases        Kelas[]
  periodePpdbs   PeriodePpdb[]
  tagihans       Tagihan[]
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nama])
  @@map("tahun_ajarans")
}

model Kelas {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  unitId        String      @map("unit_id")
  tahunAjaranId String      @map("tahun_ajaran_id")
  nama          String
  tingkat       String?
  kapasitas     Int         @default(30)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  tahunAjaran   TahunAjaran @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  unit          Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siswas        Siswa[]

  @@map("kelases")
}

model Siswa {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  userId       String?   @map("user_id")
  kelasId      String?   @map("kelas_id")
  unitId       String?   @map("unit_id")
  nis          String
  nisn         String?
  namaLengkap  String    @map("nama_lengkap")
  jenisKelamin String?   @map("jenis_kelamin")
  tempatLahir  String?   @map("tempat_lahir")
  tanggalLahir DateTime? @map("tanggal_lahir")
  alamat       String?
  telepon      String?
  fotoUrl      String?   @map("foto_url")
  namaWali     String?   @map("nama_wali")
  teleponWali  String?   @map("telepon_wali")
  emailWali    String?   @map("email_wali")
  status       String    @default("AKTIF")
  dataTambahan Json?     @map("data_tambahan")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  unit         Unit?     @relation(fields: [unitId], references: [id])
  kelas        Kelas?    @relation(fields: [kelasId], references: [id])
  user         User?     @relation(fields: [userId], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tabungan     Tabungan?
  tagihans     Tagihan[]

  @@unique([tenantId, nis])
  @@map("siswas")
}

model KategoriTagihan {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  nama      String
  kode      String
  isBulanan Boolean   @default(false) @map("is_bulanan")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tagihans  Tagihan[]

  @@unique([tenantId, kode])
  @@map("kategori_tagihans")
}

model Rekening {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  namaBank    String       @map("nama_bank")
  noRekening  String       @map("no_rekening")
  atasNama    String       @map("atas_nama")
  logoUrl     String?      @map("logo_url")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  pembayarans Pembayaran[]
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("rekenings")
}

model Tagihan {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  siswaId       String          @map("siswa_id")
  kategoriId    String          @map("kategori_id")
  tahunAjaranId String          @map("tahun_ajaran_id")
  bulan         String?
  nominal       Decimal
  potongan      Decimal         @default(0)
  total         Decimal
  status        String          @default("BELUM_LUNAS")
  jatuhTempo    DateTime?       @map("jatuh_tempo")
  keterangan    String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  pembayarans   Pembayaran[]
  tahunAjaran   TahunAjaran     @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  kategori      KategoriTagihan @relation(fields: [kategoriId], references: [id], onDelete: Cascade)
  siswa         Siswa           @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tagihans")
}

model Pembayaran {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  tagihanId    String        @map("tagihan_id")
  petugasId    String?       @map("petugas_id")
  rekeningId   String?       @map("rekening_id")
  noTransaksi  String        @map("no_transaksi")
  jumlahBayar  Decimal       @map("jumlah_bayar")
  metode       String        @default("TUNAI")
  status       String        @default("BERHASIL")
  buktiUrl     String?       @map("bukti_url")
  tanggalBayar DateTime      @default(now()) @map("tanggal_bayar")
  keterangan   String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  rekening     Rekening?     @relation(fields: [rekeningId], references: [id])
  petugas      User?         @relation("PetugasPembayaran", fields: [petugasId], references: [id])
  tagihan      Tagihan       @relation(fields: [tagihanId], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transaksiKas TransaksiKas?

  @@unique([tenantId, noTransaksi])
  @@map("pembayarans")
}

model AkunKas {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  nama         String
  kode         String
  tipe         String
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transaksiKas TransaksiKas[]

  @@unique([tenantId, kode])
  @@map("akun_kas")
}

model TransaksiKas {
  id           String      @id @default(uuid())
  tenantId     String      @map("tenant_id")
  akunKasId    String      @map("akun_kas_id")
  pembayaranId String?     @unique @map("pembayaran_id")
  jenis        String
  nominal      Decimal
  keterangan   String?
  tanggal      DateTime    @default(now())
  isOtomatis   Boolean     @default(false) @map("is_otomatis")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  pembayaran   Pembayaran? @relation(fields: [pembayaranId], references: [id])
  akunKas      AkunKas     @relation(fields: [akunKasId], references: [id], onDelete: Cascade)
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("transaksi_kas")
}

model Tabungan {
  id                 String              @id @default(uuid())
  tenantId           String              @map("tenant_id")
  siswaId            String              @unique @map("siswa_id")
  saldo              Decimal             @default(0)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  siswa              Siswa               @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transaksiTabungans TransaksiTabungan[]

  @@map("tabungans")
}

model TransaksiTabungan {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  tabunganId   String   @map("tabungan_id")
  petugasId    String?  @map("petugas_id")
  jenis        String
  nominal      Decimal
  saldoSebelum Decimal  @map("saldo_sebelum")
  saldoSesudah Decimal  @map("saldo_sesudah")
  tanggal      DateTime @default(now())
  keterangan   String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  petugas      User?    @relation("PetugasTabungan", fields: [petugasId], references: [id])
  tabungan     Tabungan @relation(fields: [tabunganId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("transaksi_tabungans")
}

model PeriodePpdb {
  id                String              @id @default(uuid())
  tenantId          String              @map("tenant_id")
  tahunAjaranId     String              @map("tahun_ajaran_id")
  unitId            String?             @map("unit_id")
  nama              String
  tanggalBuka       DateTime            @map("tanggal_buka")
  tanggalTutup      DateTime            @map("tanggal_tutup")
  isActive          Boolean             @default(true) @map("is_active")
  pengaturan        Json?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  pendaftars        PendaftarPpdb[]
  unit              Unit?               @relation(fields: [unitId], references: [id])
  tahunAjaran       TahunAjaran         @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  persyaratanBerkas PersyaratanBerkas[]

  @@map("periode_ppdbs")
}

model PendaftarPpdb {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  periodeId        String        @map("periode_id")
  userId           String?       @map("user_id")
  noPendaftaran    String        @map("no_pendaftaran")
  namaLengkap      String        @map("nama_lengkap")
  dataFormulir     Json?         @map("data_formulir")
  status           String        @default("MENUNGGU")
  jalurPendaftaran String?       @map("jalur_pendaftaran")
  jurusanPilihan   String?       @map("jurusan_pilihan")
  dataOrangtua     Json?         @map("data_orangtua")
  tanggalDaftar    DateTime      @default(now()) @map("tanggal_daftar")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  berkas           BerkasPpdb[]
  user             User?         @relation(fields: [userId], references: [id])
  periode          PeriodePpdb   @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tagihanPpdbs     TagihanPpdb[]

  @@unique([tenantId, noPendaftaran])
  @@map("pendaftar_ppdbs")
}

model PersyaratanBerkas {
  id        String       @id @default(uuid())
  tenantId  String       @map("tenant_id")
  periodeId String       @map("periode_id")
  nama      String
  isWajib   Boolean      @default(true) @map("is_wajib")
  tipeFile  String?      @map("tipe_file")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  berkas    BerkasPpdb[]
  periode   PeriodePpdb  @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("persyaratan_berkas")
}

model BerkasPpdb {
  id            String            @id @default(uuid())
  tenantId      String            @map("tenant_id")
  pendaftarId   String            @map("pendaftar_id")
  persyaratanId String            @map("persyaratan_id")
  fileUrl       String?           @map("file_url")
  status        String            @default("MENUNGGU")
  catatan       String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  persyaratan   PersyaratanBerkas @relation(fields: [persyaratanId], references: [id], onDelete: Cascade)
  pendaftar     PendaftarPpdb     @relation(fields: [pendaftarId], references: [id], onDelete: Cascade)
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("berkas_ppdbs")
}

model TagihanPpdb {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  pendaftarId String           @map("pendaftar_id")
  jenis       String
  nominal     Decimal
  status      String           @default("BELUM_LUNAS")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  pendaftar   PendaftarPpdb    @relation(fields: [pendaftarId], references: [id], onDelete: Cascade)
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pembayarans PembayaranPpdb[]

  @@map("tagihan_ppdbs")
}

model PembayaranPpdb {
  id           String      @id @default(uuid())
  tenantId     String      @map("tenant_id")
  tagihanId    String      @map("tagihan_id")
  noTransaksi  String?     @map("no_transaksi")
  nominal      Decimal
  metode       String?     @default("MANUAL")
  tanggalBayar DateTime    @default(now()) @map("tanggal_bayar")
  status       String      @default("PENDING")
  buktiUrl     String?     @map("bukti_url")
  keterangan   String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  tagihan      TagihanPpdb @relation(fields: [tagihanId], references: [id], onDelete: Cascade)
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("pembayaran_ppdbs")
}

model Berita {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  userId        String    @map("user_id")
  judul         String
  slug          String
  konten        String
  ringkasan     String?
  gambarUrl     String?   @map("gambar_url")
  kategori      String    @default("BERITA")
  status        String    @default("DRAFT")
  tanggalTerbit DateTime? @map("tanggal_terbit")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@map("beritas")
}

