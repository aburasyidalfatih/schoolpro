// ============================================================
// SISPRO — Prisma Schema (Multi-Tenant SaaS-Ready)
// Database: MySQL (siap migrasi ke PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// TENANT — Tabel utama multi-tenant (setiap sekolah = 1 tenant)
// ============================================================
model Tenant {
  id              String   @id @default(uuid())
  nama            String
  slug            String   @unique
  domainKustom    String?  @map("domain_kustom")
  logoUrl         String?  @map("logo_url")
  alamat          String?
  telepon         String?
  email           String?
  website         String?
  mediaSosial     Json?    @map("media_sosial")
  pengaturan      Json?
  paket           Paket    @default(FREE)
  berlanggananSampai DateTime? @map("berlangganan_sampai")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  users              User[]
  units              Unit[]
  tahunAjarans       TahunAjaran[]
  kelases            Kelas[]
  siswas             Siswa[]
  kategoriTagihans   KategoriTagihan[]
  rekenings          Rekening[]
  tagihans           Tagihan[]
  pembayarans        Pembayaran[]
  transaksiKas       TransaksiKas[]
  akunKas            AkunKas[]
  tabungans          Tabungan[]
  transaksiTabungans TransaksiTabungan[]
  pendaftarPpdbs     PendaftarPpdb[]
  periodePpdbs       PeriodePpdb[]
  berkasPpdbs        BerkasPpdb[]
  persyaratanBerkas  PersyaratanBerkas[]
  tagihanPpdbs       TagihanPpdb[]
  beritas            Berita[]
  pengumumans        Pengumuman[]
  logAktivitas       LogAktivitas[]
  pengaturanNotifikasi PengaturanNotifikasi[]

  @@map("tenants")
}

enum Paket {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

// ============================================================
// USER — Akun pengguna (multi-role)
// ============================================================
model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  nama         String
  email        String
  username     String
  passwordHash String   @map("password_hash")
  role         Role     @default(STAF)
  isActive     Boolean  @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siswas       Siswa[]
  pembayarans  Pembayaran[] @relation("PetugasPembayaran")
  transaksiTabungans TransaksiTabungan[] @relation("PetugasTabungan")
  beritas      Berita[]
  pengumumans  Pengumuman[]
  logAktivitas LogAktivitas[]

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  KEUANGAN
  TU
  STAF
  PPDB
  WALI
  SISWA
}

// ============================================================
// UNIT — Jenjang/unit sekolah (SD, SMP, SMA, dll)
// ============================================================
model Unit {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  nama     String
  kode     String
  isActive Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kelases  Kelas[]
  siswas   Siswa[]
  periodePpdbs PeriodePpdb[]

  @@unique([tenantId, kode])
  @@map("units")
}

// ============================================================
// TAHUN AJARAN
// ============================================================
model TahunAjaran {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  nama          String
  tanggalMulai  DateTime @map("tanggal_mulai")
  tanggalSelesai DateTime @map("tanggal_selesai")
  isActive      Boolean  @default(false) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kelases      Kelas[]
  tagihans     Tagihan[]
  periodePpdbs PeriodePpdb[]

  @@unique([tenantId, nama])
  @@map("tahun_ajarans")
}

// ============================================================
// KELAS
// ============================================================
model Kelas {
  id            String @id @default(uuid())
  tenantId      String @map("tenant_id")
  unitId        String @map("unit_id")
  tahunAjaranId String @map("tahun_ajaran_id")
  nama          String
  tingkat       String?
  kapasitas     Int    @default(30)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit        Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tahunAjaran TahunAjaran @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  siswas      Siswa[]

  @@map("kelases")
}

// ============================================================
// SISWA
// ============================================================
model Siswa {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  userId        String?     @map("user_id")
  kelasId       String?     @map("kelas_id")
  unitId        String?     @map("unit_id")
  nis           String
  nisn          String?
  namaLengkap   String      @map("nama_lengkap")
  jenisKelamin  JenisKelamin? @map("jenis_kelamin")
  tempatLahir   String?     @map("tempat_lahir")
  tanggalLahir  DateTime?   @map("tanggal_lahir")
  alamat        String?
  telepon       String?
  fotoUrl       String?     @map("foto_url")
  namaWali      String?     @map("nama_wali")
  teleponWali   String?     @map("telepon_wali")
  emailWali     String?     @map("email_wali")
  status        StatusSiswa @default(AKTIF)
  dataTambahan  Json?       @map("data_tambahan")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  kelas     Kelas?     @relation(fields: [kelasId], references: [id], onDelete: SetNull)
  unit      Unit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tagihans  Tagihan[]
  tabungan  Tabungan?

  @@unique([tenantId, nis])
  @@map("siswas")
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusSiswa {
  AKTIF
  TIDAK_AKTIF
  LULUS
  PINDAH
}

// ============================================================
// KATEGORI TAGIHAN (SPP, Buku, Kegiatan, dll)
// ============================================================
model KategoriTagihan {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  nama      String
  kode      String
  isBulanan Boolean @default(false) @map("is_bulanan")
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tagihans Tagihan[]

  @@unique([tenantId, kode])
  @@map("kategori_tagihans")
}

// ============================================================
// REKENING PEMBAYARAN
// ============================================================
model Rekening {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  namaBank    String  @map("nama_bank")
  noRekening  String  @map("no_rekening")
  atasNama    String  @map("atas_nama")
  logoUrl     String? @map("logo_url")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pembayarans Pembayaran[]

  @@map("rekenings")
}

// ============================================================
// TAGIHAN
// ============================================================
model Tagihan {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  siswaId       String        @map("siswa_id")
  kategoriId    String        @map("kategori_id")
  tahunAjaranId String        @map("tahun_ajaran_id")
  bulan         String?
  nominal       Decimal
  potongan      Decimal       @default(0)
  total         Decimal
  status        StatusTagihan @default(BELUM_LUNAS)
  jatuhTempo    DateTime?     @map("jatuh_tempo")
  keterangan    String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siswa       Siswa           @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  kategori    KategoriTagihan @relation(fields: [kategoriId], references: [id], onDelete: Cascade)
  tahunAjaran TahunAjaran     @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  pembayarans Pembayaran[]

  @@map("tagihans")
}

enum StatusTagihan {
  BELUM_LUNAS
  LUNAS
  SEBAGIAN
}

// ============================================================
// PEMBAYARAN
// ============================================================
model Pembayaran {
  id            String           @id @default(uuid())
  tenantId      String           @map("tenant_id")
  tagihanId     String           @map("tagihan_id")
  petugasId     String?          @map("petugas_id")
  rekeningId    String?          @map("rekening_id")
  noTransaksi   String           @map("no_transaksi")
  jumlahBayar   Decimal          @map("jumlah_bayar")
  metode        MetodeBayar      @default(TUNAI)
  status        StatusPembayaran @default(BERHASIL)
  buktiUrl      String?          @map("bukti_url")
  tanggalBayar  DateTime         @default(now()) @map("tanggal_bayar")
  keterangan    String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tagihan      Tagihan      @relation(fields: [tagihanId], references: [id], onDelete: Cascade)
  petugas      User?        @relation("PetugasPembayaran", fields: [petugasId], references: [id], onDelete: SetNull)
  rekening     Rekening?    @relation(fields: [rekeningId], references: [id], onDelete: SetNull)
  transaksiKas TransaksiKas?

  @@unique([tenantId, noTransaksi])
  @@map("pembayarans")
}

enum MetodeBayar {
  TUNAI
  TRANSFER
  QRIS
}

enum StatusPembayaran {
  BERHASIL
  PENDING
  GAGAL
  DIBATALKAN
}

// ============================================================
// AKUN KAS
// ============================================================
model AkunKas {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  nama     String
  kode     String
  tipe     TipeKas
  isActive Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transaksiKas TransaksiKas[]

  @@unique([tenantId, kode])
  @@map("akun_kas")
}

enum TipeKas {
  PEMASUKAN
  PENGELUARAN
}

// ============================================================
// TRANSAKSI KAS
// ============================================================
model TransaksiKas {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  akunKasId    String   @map("akun_kas_id")
  pembayaranId String?  @unique @map("pembayaran_id")
  jenis        TipeKas
  nominal      Decimal
  keterangan   String?
  tanggal      DateTime @default(now())
  isOtomatis   Boolean  @default(false) @map("is_otomatis")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  akunKas    AkunKas     @relation(fields: [akunKasId], references: [id], onDelete: Cascade)
  pembayaran Pembayaran? @relation(fields: [pembayaranId], references: [id], onDelete: SetNull)

  @@map("transaksi_kas")
}

// ============================================================
// TABUNGAN
// ============================================================
model Tabungan {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  siswaId  String  @unique @map("siswa_id")
  saldo    Decimal @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siswa    Siswa               @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  transaksiTabungans TransaksiTabungan[]

  @@map("tabungans")
}

// ============================================================
// TRANSAKSI TABUNGAN
// ============================================================
model TransaksiTabungan {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  tabunganId   String        @map("tabungan_id")
  petugasId    String?       @map("petugas_id")
  jenis        JenisTabungan
  nominal      Decimal
  saldoSebelum Decimal       @map("saldo_sebelum")
  saldoSesudah Decimal       @map("saldo_sesudah")
  tanggal      DateTime      @default(now())
  keterangan   String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tabungan Tabungan @relation(fields: [tabunganId], references: [id], onDelete: Cascade)
  petugas  User?    @relation("PetugasTabungan", fields: [petugasId], references: [id], onDelete: SetNull)

  @@map("transaksi_tabungans")
}

enum JenisTabungan {
  SETORAN
  PENARIKAN
}

// ============================================================
// PPDB — Periode Pendaftaran
// ============================================================
model PeriodePpdb {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  tahunAjaranId String   @map("tahun_ajaran_id")
  unitId        String?  @map("unit_id")
  nama          String
  tanggalBuka   DateTime @map("tanggal_buka")
  tanggalTutup  DateTime @map("tanggal_tutup")
  isActive      Boolean  @default(true) @map("is_active")
  pengaturan    Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tahunAjaran      TahunAjaran        @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  unit             Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  pendaftars       PendaftarPpdb[]
  persyaratanBerkas PersyaratanBerkas[]

  @@map("periode_ppdbs")
}

// ============================================================
// PPDB — Data Pendaftar
// ============================================================
model PendaftarPpdb {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  periodeId       String         @map("periode_id")
  noPendaftaran   String         @map("no_pendaftaran")
  namaLengkap     String         @map("nama_lengkap")
  dataFormulir    Json?          @map("data_formulir")
  status          StatusPpdb     @default(MENUNGGU)
  jalurPendaftaran String?       @map("jalur_pendaftaran")
  jurusanPilihan  String?        @map("jurusan_pilihan")
  dataOrangtua    Json?          @map("data_orangtua")
  tanggalDaftar   DateTime       @default(now()) @map("tanggal_daftar")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periode     PeriodePpdb   @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  berkas      BerkasPpdb[]
  tagihanPpdbs TagihanPpdb[]

  @@unique([tenantId, noPendaftaran])
  @@map("pendaftar_ppdbs")
}

enum StatusPpdb {
  MENUNGGU
  TERVERIFIKASI
  DITERIMA
  DITOLAK
}

// ============================================================
// PPDB — Persyaratan Berkas
// ============================================================
model PersyaratanBerkas {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  periodeId String  @map("periode_id")
  nama      String
  isWajib   Boolean @default(true) @map("is_wajib")
  tipeFile  String? @map("tipe_file")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periode PeriodePpdb @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  berkas  BerkasPpdb[]

  @@map("persyaratan_berkas")
}

// ============================================================
// PPDB — Berkas Pendaftar
// ============================================================
model BerkasPpdb {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  pendaftarId    String       @map("pendaftar_id")
  persyaratanId  String       @map("persyaratan_id")
  fileUrl        String?      @map("file_url")
  status         StatusBerkas @default(MENUNGGU)
  catatan        String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pendaftar   PendaftarPpdb     @relation(fields: [pendaftarId], references: [id], onDelete: Cascade)
  persyaratan PersyaratanBerkas @relation(fields: [persyaratanId], references: [id], onDelete: Cascade)

  @@map("berkas_ppdbs")
}

enum StatusBerkas {
  MENUNGGU
  DITERIMA
  DITOLAK
}

// ============================================================
// PPDB — Tagihan PPDB
// ============================================================
model TagihanPpdb {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  pendaftarId String          @map("pendaftar_id")
  jenis       JenisTagihanPpdb
  nominal     Decimal
  status      StatusTagihan   @default(BELUM_LUNAS)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pendaftar PendaftarPpdb @relation(fields: [pendaftarId], references: [id], onDelete: Cascade)

  @@map("tagihan_ppdbs")
}

enum JenisTagihanPpdb {
  PENDAFTARAN
  DAFTAR_ULANG
}

// ============================================================
// BERITA
// ============================================================
model Berita {
  id           String       @id @default(uuid())
  tenantId     String       @map("tenant_id")
  userId       String       @map("user_id")
  judul        String
  slug         String
  konten       String
  gambarUrl    String?      @map("gambar_url")
  status       StatusBerita @default(DRAFT)
  tanggalTerbit DateTime?   @map("tanggal_terbit")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@map("beritas")
}

enum StatusBerita {
  DRAFT
  TERBIT
}

// ============================================================
// PENGUMUMAN
// ============================================================
model Pengumuman {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  judul       String
  konten      String
  targetKelas Json?    @map("target_kelas")
  kirimWa     Boolean  @default(false) @map("kirim_wa")
  tanggal     DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pengumumans")
}

// ============================================================
// LOG AKTIVITAS
// ============================================================
model LogAktivitas {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String?  @map("user_id")
  aksi      String
  modul     String
  detail    String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("log_aktivitas")
}

// ============================================================
// PENGATURAN NOTIFIKASI
// ============================================================
model PengaturanNotifikasi {
  id           String  @id @default(uuid())
  tenantId     String  @map("tenant_id")
  jenis        String
  viaApp       Boolean @default(true) @map("via_app")
  viaWa        Boolean @default(false) @map("via_wa")
  viaEmail     Boolean @default(false) @map("via_email")
  templatePesan String? @map("template_pesan")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("pengaturan_notifikasi")
}
